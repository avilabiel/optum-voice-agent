# Database
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# Vapi
VAPI_API_KEY=
VAPI_ASSISTANT_ID=
VAPI_PHONE_NUMBER_ID=
# Pick any random string — setup-vapi pushes it to Vapi and our webhook verifies it.
# Generate one with: openssl rand -hex 32
VAPI_WEBHOOK_SECRET=
# 11Labs voice: jessica | laura | eric (default: jessica)
VAPI_VOICE_NAME=jessica

# LLM
OPENAI_API_KEY=
OPENAI_ASSISTANT_MODEL=gpt-4o
OPENAI_JUDGE_MODEL=gpt-4o-mini

# Inngest (optional in dev)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Langfuse
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Demo
DEMO_PHONE_NUMBER=
PUBLIC_API_URL=http://localhost:3000
NGROK_URL=

# Tenant (single tenant for the demo)
DEMO_TENANT_NAME=Optum
